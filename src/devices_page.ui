<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="Adw" version="1.0"/>
  <template class="PinepalDevicesPage" parent="GtkBox">
    <property name="orientation">vertical</property>
    <property name="spacing">12</property>
    <property name="margin-start">16</property>
    <property name="margin-end">16</property>
    <property name="margin-top">16</property>
    <property name="margin-bottom">16</property>

    <child>
      <object class="AdwStatusPage" id="status_page">
        <property name="icon-name">bluetooth-symbolic</property>
        <property name="title" translatable="yes">Looking for InfiniTime…</property>
        <property name="description" translatable="yes">Make sure your PineTime is nearby and Bluetooth is enabled.</property>
        <property name="vexpand">true</property>
        <property name="child">
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="spacing">12</property>
            <property name="halign">center</property>
            <child>
              <object class="GtkSpinner" id="scan_spinner">
                <property name="spinning">true</property>
                <property name="width-request">32</property>
                <property name="height-request">32</property>
              </object>
            </child>
            <child>
              <object class="GtkListBox" id="device_list">
                <property name="selection-mode">none</property>
                <property name="css-classes">boxed-list</property>
                <property name="width-request">300</property>
                <property name="visible">false</property>
              </object>
            </child>
          </object>
        </property>
      </object>
    </child>
  </template>
</interface>
