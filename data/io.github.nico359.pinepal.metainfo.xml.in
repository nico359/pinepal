<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.nico359.pinepal</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>PinePal</name>
  <summary>Companion app for PineTime watches</summary>
  <description>
    <p>PinePal is a companion app for PineTime smartwatches running InfiniTime. Connect via Bluetooth LE to view battery, heart rate, and step count, forward notifications from your phone, and track your step history over time.</p>
  </description>

  <icon type="stock">io.github.nico359.pinepal</icon>

  <developer id="io.github.nico359">
    <name>nico359</name>
  </developer>

  <url type="homepage">https://github.com/nico359/pinepal</url>
  <url type="vcs-browser">https://github.com/nico359/pinepal</url>
  <url type="bugtracker">https://github.com/nico359/pinepal/issues</url>

  <translation type="gettext">pinepal</translation>
  <launchable type="desktop-id">io.github.nico359.pinepal.desktop</launchable>
  <content_rating type="oars-1.1" />

  <releases>
    <release version="0.2.0" date="2026-04-18">
      <description translate="no">
        <p>Stability and usability improvements.</p>
        <ul>
          <li>Added app icon</li>
          <li>Improved BLE reconnection reliability on the FuriPhone</li>
          <li>Removed unnecessary network access from the Flatpak manifest</li>
          <li>Added in-app diagnostic log viewer and export (Ctrl+Shift+D)</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-04-10">
      <description translate="no">
        <p>Initial release.</p>
        <ul>
          <li>BLE connection with automatic reconnection</li>
          <li>Live battery, heart rate, and step count</li>
          <li>Step history chart with daily persistence</li>
          <li>Desktop notification forwarding</li>
          <li>Background mode</li>
        </ul>
      </description>
    </release>
  </releases>

</component>
